# AI API 配置（豆包/OpenAI）
# 禁止将此文件重命名为 .env 后提交到 Git 仓库！
# 使用时复制此文件为 .env 并填入真实密钥

# OpenAI / 豆包 API Key
VITE_AI_API_KEY=your_api_key_here

# AI API Base URL（豆包示例：https://ark.cn-beijing.volces.com/api/v3）
VITE_AI_API_BASE_URL=https://api.openai.com/v1

# AI Model Name
VITE_AI_MODEL=gpt-3.5-turbo

# Server Port
PORT=3001
